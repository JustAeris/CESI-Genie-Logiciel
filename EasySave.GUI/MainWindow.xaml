<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySave.GUI"
        xmlns:svc="clr-namespace:EasySave.GUI.Services"
        mc:Ignorable="d"
        Title="EasySave" Height="550" Width="950"
        Background="{StaticResource BgColor}"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header top bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#111111" Height="48"
                BorderThickness="0,0,0,2" BorderBrush="#F5D800">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="CESI" Foreground="#F5D800"
                               FontFamily="Consolas" FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="_" Foreground="#F5D800"
                               FontFamily="Consolas" FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="EasySave v3.0"
                           Foreground="#444444" FontFamily="Consolas"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="10,0"/>
                <!-- Language toggle -->
                <Button Grid.Column="2"
                        Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=LangToggle}"
                        Command="{Binding ToggleLanguageCommand}"
                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                        Foreground="#F5D800" Background="Transparent"
                        BorderThickness="1" BorderBrush="#F5D800"
                        Padding="10,4" Margin="0,0,16,0"
                        VerticalAlignment="Center" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarColor}"
                BorderThickness="0,0,1,0" BorderBrush="#1A1A1A">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavLabel}"
                           Foreground="#444444"
                           FontFamily="Consolas" FontSize="10"
                           Margin="20,0,0,10"/>
                <Button Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavBackups}"
                        Command="{Binding NavigateToJobsCommand}"
                        Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NavSettings}"
                        Command="{Binding NavigateToSettingsCommand}"
                        Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource BgColor}">
            <ContentControl Content="{Binding Navigation.CurrentViewModel}"
                            Margin="20"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#111111" Height="28"
                BorderThickness="0,1,0,0" BorderBrush="#1A1A1A">
            <TextBlock Text="{Binding Status.Message}"
                       Foreground="#00FF41" FontFamily="Consolas" FontSize="11"
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>
    </Grid>
</Window>
