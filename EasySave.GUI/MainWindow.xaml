<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySave.GUI"
        mc:Ignorable="d"
        Title="EasySave" Height="500" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu latéral gauche -->
        <StackPanel Grid.Column="0" Background="#2D2D2D">
            <TextBlock Text="EasySave" Foreground="White" FontSize="18"
                       FontWeight="Bold" Margin="20,20,0,30"/>
            <Button Content="Sauvegardes"
                    Command="{Binding NavigateToJobsCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Paramètres"
                    Command="{Binding NavigateToSettingsCommand}"
                    Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>

        <!-- Zone de contenu à droite -->
        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}"/>
    </Grid>
</Window>
