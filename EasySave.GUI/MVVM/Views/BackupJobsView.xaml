<UserControl x:Class="EasySave.GUI.MVVM.Views.BackupJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EasySave.GUI.MVVM.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="// SAUVEGARDES" Foreground="#F5D800"
                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"/>
            <Rectangle Height="1" Fill="#F5D800" Margin="0,6,0,0" Opacity="0.3"/>
        </StackPanel>

        <!-- Liste des jobs -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Jobs}"
                 SelectedItem="{Binding SelectedJob}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,4"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#1A1A1A" BorderThickness="1"
                            Background="#111111" Padding="12,10"
                            Margin="0,2">
                        <StackPanel>
                            <!-- Nom + contrôles playback -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="► " Foreground="#F5D800"
                                           FontFamily="Consolas" FontSize="13"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="#F0F0F0"
                                           FontFamily="Consolas" FontSize="13"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="⏸" ToolTip="Pause"
                                        Command="{Binding DataContext.PauseJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Padding="8,2" Margin="12,0,4,0"/>
                                <Button Content="▶" ToolTip="Resume"
                                        Command="{Binding DataContext.ResumeJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Padding="8,2" Margin="0,0,4,0"/>
                                <Button Content="⏹" ToolTip="Stop"
                                        Command="{Binding DataContext.StopJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Padding="8,2"/>
                            </StackPanel>

                            <!-- Chemin source -->
                            <TextBlock Text="{Binding SourceDir}" Foreground="#555555"
                                       FontFamily="Consolas" FontSize="11"
                                       Margin="16,2,0,4"/>

                            <!-- Barre de progression -->
                            <ProgressBar Value="{Binding Progression}" Maximum="100"
                                         Height="3" Margin="0,2,0,0"
                                         Background="#1A1A1A" Foreground="#00FF41"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Boutons globaux -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="▶ RUN" Command="{Binding RunJobCommand}"
                    Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="▶▶ RUN ALL" Command="{Binding RunAllCommand}"
                    Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="+ ADD" Command="{Binding AddJobCommand}"
                    Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="✕ DEL" Command="{Binding RemoveJobCommand}"
                    Style="{StaticResource DangerButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
