<Window x:Class="EasySave.GUI.MVVM.Views.AddJobDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySave.GUI.MVVM.Views"
        xmlns:svc="clr-namespace:EasySave.GUI.Services"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=AddJobTitle}"
        Height="280" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=NameLabel}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=SourceLabel}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="SourceBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Text="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=DestLabel}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="5" x:Name="TargetBox" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=CancelButton}"
                    Click="Cancel_Click" Padding="15,8" Margin="0,0,10,0"/>
            <Button Content="{Binding Source={x:Static svc:LocalizationService.Instance}, Path=AddButton}"
                    Click="Add_Click" Padding="15,8"/>
        </StackPanel>
    </Grid>
</Window>
