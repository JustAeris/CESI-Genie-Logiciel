<Window x:Class="EasySave.GUI.MVVM.Views.ToastNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <Border Background="#111111" BorderBrush="#F5D800" BorderThickness="1"
            Padding="16,12" CornerRadius="2">
        <StackPanel>
            <TextBlock x:Name="TitleText" Foreground="#F5D800"
                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
            <TextBlock x:Name="BodyText" Foreground="#F0F0F0"
                       FontFamily="Consolas" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</Window>
